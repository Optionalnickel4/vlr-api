# copy to .env and adjust. chmod 600.
# Replace CHANGEME in the password slot before deploying.
VLR_DATABASE_URL=postgresql+asyncpg://vlr:CHANGEME@localhost:5432/vlr
VLR_REDIS_URL=redis://:CHANGEME@localhost:6379/0

VLR_USER_AGENT=vlr-api/0.1 (self-hosted; +https://jushosting.dev)
VLR_MIN_REQUEST_INTERVAL=1.5
VLR_ENABLE_SCHEDULER=true
